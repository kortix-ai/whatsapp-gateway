DOMAIN=whatsapp.example.com
POSTGRES_DB=whatsapp_gateway
POSTGRES_USER=whatsapp_gateway
POSTGRES_PASSWORD=replace-with-a-long-random-password
DATABASE_URL=postgresql://whatsapp_gateway:replace-with-a-long-random-password@postgres:5432/whatsapp_gateway
BETTER_AUTH_SECRET=replace-with-at-least-32-random-characters
ENCRYPTION_KEY=replace-with-32-byte-base64-key
AUTH_ALLOWLIST_ENABLED=true
ALLOWED_EMAILS=marko@kortix.ai
WORKER_CAPACITY=25
PAIRING_TTL_SECONDS=300
WEBHOOK_MAX_ATTEMPTS=12
