NODE_ENV=development
PORT=8080
WEB_ORIGIN=http://localhost:3000
AUTH_ALLOWLIST_ENABLED=true
ALLOWED_EMAILS=marko@kortix.ai
PUBLIC_BASE_URL=http://localhost:8080
DATABASE_URL=postgresql://postgres:postgres@localhost:54329/whatsapp_gateway
BETTER_AUTH_SECRET=replace-with-at-least-32-random-characters
BETTER_AUTH_URL=http://localhost:8080
# 32-byte key, base64 encoded. Generate: openssl rand -base64 32
ENCRYPTION_KEY=replace-with-32-byte-base64-key
WORKER_ID=
WORKER_CAPACITY=25
LEASE_TTL_SECONDS=30
LEASE_HEARTBEAT_SECONDS=10
PAIRING_TTL_SECONDS=300
WEBHOOK_POLL_INTERVAL_MS=1000
WEBHOOK_MAX_ATTEMPTS=12
ALLOW_PRIVATE_WEBHOOKS=false
ALLOW_INSECURE_DEVELOPMENT_DEFAULTS=false
