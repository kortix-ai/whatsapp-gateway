{
  "name": "@kortix/whatsapp-gateway",
  "version": "0.1.0",
  "private": false,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kortix-ai/whatsapp-gateway.git"
  },
  "homepage": "https://github.com/kortix-ai/whatsapp-gateway#readme",
  "bugs": {
    "url": "https://github.com/kortix-ai/whatsapp-gateway/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "wag": "dist/server/cli.js"
  },
  "files": [
    "dist/server",
    "dist/web",
    "prisma",
    "skills",
    "README.md",
    "LICENSE",
    "SECURITY.md"
  ],
  "type": "module",
  "packageManager": "pnpm@8.11.0",
  "engines": {
    "node": ">=22.19.0"
  },
  "scripts": {
    "dev": "concurrently -k -n api,worker,webhooks,web -c blue,magenta,yellow,green \"pnpm dev:api\" \"pnpm dev:worker\" \"pnpm dev:webhooks\" \"pnpm dev:web\"",
    "dev:api": "RUNTIME_ROLE=api tsx watch src/main.ts",
    "dev:worker": "RUNTIME_ROLE=worker tsx watch src/main.ts",
    "dev:webhooks": "RUNTIME_ROLE=webhooks tsx watch src/main.ts",
    "dev:web": "vite",
    "build": "pnpm db:generate && pnpm build:server && pnpm build:web",
    "build:server": "tsup src/main.ts src/cli.ts src/scripts/e2e.ts --format esm --platform node --target node22 --out-dir dist/server --splitting false --sourcemap",
    "build:web": "vite build",
    "start": "node dist/server/main.js",
    "start:api": "RUNTIME_ROLE=api node dist/server/main.js",
    "start:worker": "RUNTIME_ROLE=worker node dist/server/main.js",
    "start:webhooks": "RUNTIME_ROLE=webhooks node dist/server/main.js",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:migrate:dev": "prisma migrate dev",
    "db:studio": "prisma studio",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "pnpm db:generate && tsc --noEmit",
    "lint": "eslint .",
    "e2e": "tsx src/scripts/e2e.ts",
    "smoke:curl": "bash scripts/smoke.sh",
    "skill:validate": "node scripts/validate-skill.mjs",
    "wag": "tsx src/cli.ts"
  },
  "dependencies": {
    "@better-auth/api-key": "1.6.23",
    "@better-fetch/fetch": "1.3.1",
    "@hono/node-server": "1.19.9",
    "@hono/zod-validator": "0.7.6",
    "@prisma/client": "6.19.3",
    "@scalar/hono-api-reference": "0.11.11",
    "baileys": "7.0.0-rc13",
    "better-auth": "1.6.23",
    "hono": "4.12.31",
    "ipaddr.js": "2.3.0",
    "pino": "9.14.0",
    "qrcode": "1.5.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "undici": "8.8.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "9.39.2",
    "@types/node": "22.19.15",
    "@types/qrcode": "1.5.6",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.1.4",
    "concurrently": "9.2.1",
    "eslint": "9.39.2",
    "eslint-plugin-react-hooks": "7.0.1",
    "eslint-plugin-react-refresh": "0.5.2",
    "prisma": "6.19.3",
    "tsup": "8.5.1",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.57.0",
    "vite": "7.3.1",
    "vitest": "4.1.0"
  }
}
